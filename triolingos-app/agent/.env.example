# Agent worker (LiveKit + Soniox + Claude) — okruženje.
# Ove vrednosti idu u Coolify env za `agent` servis (ili u .env pored
# docker-compose.yml na VPS-u). NIKADA ne commit-uj popunjen fajl sa tajnama.

# LiveKit (livekit-server generate-keys)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Soniox STT/TTS — TAJNA. Vrednost dobijaš od Soniox-a; drži je samo ovde/u Coolify.
SONIOX_API_KEY=
# Opciono: srpski glas za TTS
SONIOX_VOICE_SR=default

# Claude (Anthropic) — TAJNA
ANTHROPIC_API_KEY=

# Firebase Functions bazni URL i deljena tajna agent↔functions
FUNCTIONS_BASE=https://europe-west1-triolingos.cloudfunctions.net
AGENT_SHARED_SECRET=

# Idle-cut (sekunde tišine pre prekida) — opciono
IDLE_CUT_SECONDS=20
